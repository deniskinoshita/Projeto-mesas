{
  "version": 2,
  "functions": {
    "api/auth/login.js": {
      "maxDuration": 30,
      "memory": 512
    },
    "api/index.py": {
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "crons": [
    { "path": "/api/cron/morning-call", "schedule": "0 11 * * *" }
  ],
  "routes": [
    { "src": "^/$",                          "dest": "api/auth/login.js" },
    { "src": "^/reset-senha$",               "dest": "api/auth/login.js" },
    { "src": "^/api/ping$",                  "dest": "api/auth/login.js" },
    { "src": "^/api/login$",                 "dest": "api/auth/login.js" },
    { "src": "^/api/login-pessoal$",         "dest": "api/auth/login.js" },
    { "src": "^/api/solicitar-reset$",       "dest": "api/auth/login.js" },
    { "src": "^/api/confirmar-reset$",       "dest": "api/auth/login.js" },
    { "src": "^/api/verificar-token-reset$", "dest": "api/auth/login.js" },
    { "src": "/(.*)",                        "dest": "api/index.py" }
  ]
}
